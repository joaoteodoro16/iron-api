    "version": "0.2.0",
    "configurations": [
        {
            "name": "Iron.API",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/Iron/Iron.API/bin/Debug/net10.0/Iron.Api.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Iron/Iron.API",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:7116;http://localhost:5144"
            }
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        }
    ]
}
